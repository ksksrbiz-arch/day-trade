# --- Alpaca PAPER account (https://app.alpaca.markets -> Paper Trading -> generate keys) ---
ALPACA_API_KEY=your_paper_key
ALPACA_SECRET_KEY=your_paper_secret
ALPACA_PAPER=true

# --- Anthropic (for the news labeler) ---
ANTHROPIC_API_KEY=your_anthropic_key
LLM_MODEL=claude-sonnet-4-6

# --- Strategy knobs (optional; sensible defaults baked in) ---
# UNIVERSE=AAPL,MSFT,NVDA,TSLA,SPY        # empty = allow any ticker the news names
MIN_CONFIDENCE=0.60
MIN_SENTIMENT=0.40
NOTIONAL_PER_TRADE=5.0
TAKE_PROFIT_PCT=0.05
STOP_LOSS_PCT=0.03
ALLOW_SHORT=false

# --- Backtest realism (slippage haircut applied to every fill) ---
SLIPPAGE_BPS=10
FEE_BPS=0
SIM_STARTING_CASH=100

# --- News feeds (comma-separated; defaults to WSJ/CNBC/MarketWatch markets feeds) ---
# FEEDS=https://feeds.a.dj.com/rss/RSSMarketsMain.xml,https://www.cnbc.com/id/100003114/device/rss/rss.html
POLL_SECONDS=300

# --- TensorTrade RL trader. ON BY DEFAULT. ---
# The Docker image bakes in the RL extra (INSTALL_RL=1), the RL DQN votes in the
# confluence brain (USE_RL_VOICE + USE_CONFLUENCE default true), and the retrain
# daemon (RUN_RL_DAEMON default 1) trains/refreshes models with a champion/
# challenger gate. To DISABLE, set these to false/0:
# USE_CONFLUENCE=true                 # multi-method agreement gate (RL votes here)
# USE_RL_VOICE=true                   # include the RL DQN as a confluence method
# RUN_RL_DAEMON=1                     # champion/challenger retrain daemon
# RL_RETRAIN_EVERY_H=12
# RL_RETRAIN_EPISODES=12
# RL_UNIVERSE=AAPL,MSFT,NVDA          # daemon/standalone symbols (else a liquid basket)
# RL_WINDOW=20                        # observation lookback (bars)
# RL_MODEL_DIR=                       # empty -> data/rl
# MODE=rl                             # OPTIONAL: run RL as the standalone brain
#                                     # (replaces news/scalper/daytrader)
# Local dev without the heavy extra: leave it uninstalled -- the RL voice/daemon
# self-skip cleanly (trader.rl.available() gates everything).
